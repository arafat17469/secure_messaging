# Leave secrets blank for local development; the app creates ignored keys in instance/.
# Production must provide independent high-entropy URL-safe values and back them up.
SECRET_KEY=
MESSAGE_ENCRYPTION_KEY=
PRIVATE_KEY_KEK=

DATABASE_URL=sqlite:///secure_chat.db

# Password storage: salted PBKDF2-HMAC-SHA512 (OWASP baseline for SHA-512).
PASSWORD_HASH_ITERATIONS=220000
MIN_PASSWORD_LENGTH=8
MAX_PASSWORD_LENGTH=128
PASSWORD_REQUIRE_COMPLEXITY=False

MAX_LOGIN_ATTEMPTS=10
LOCK_MINUTES=5
JWT_EXPIRE_HOURS=6
MAX_MESSAGE_CHARS=2000
MAX_JSON_BYTES=262144
MAX_PROFILE_IMAGE_BYTES=2097152
MAX_ATTACHMENT_BYTES=15728640

# Same-origin Flask use needs no wildcard CORS. Add only trusted frontend origins.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000
TRUST_PROXY_HEADERS=False
RELAX_SECURITY_HEADERS=False
DEMO_DB_VIEW_ENABLED=False
FLASK_DEBUG=False
